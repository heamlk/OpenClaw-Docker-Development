# OpenClaw Agent - Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Slack API Configuration
# Use Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
# Optional: App-level token for Socket Mode (if using)
# SLACK_APP_TOKEN=xapp-your-app-token-here

# Google Sheets API Configuration
# Option 1: Service Account JSON (recommended for server environments)
# Set this to the path of your service account JSON file (if mounting)
# Or provide the JSON content directly (see Option 2)
GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account.json

# Option 2: Service Account JSON as environment variable (base64 encoded)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Option 3: OAuth2 Credentials (for user-based access)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REFRESH_TOKEN=your-refresh-token

# Application Configuration
# Set to 'development' or 'production'
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Custom API endpoints (if using proxies)
# OPENAI_API_BASE=https://api.openai.com/v1
# SLACK_API_BASE=https://api.slack.com
